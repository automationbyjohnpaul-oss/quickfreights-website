# ==========================================
# QuickFreights Platform
# Git Ignore Rules
# ==========================================

# --------------------------
# Operating System
# --------------------------
.DS_Store
Thumbs.db
Desktop.ini

# --------------------------
# Logs
# --------------------------
*.log
logs/

# --------------------------
# Environment Files
# --------------------------
.env
.env.*
!.env.example

# --------------------------
# Node.js
# --------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --------------------------
# Build Output
# --------------------------
dist/
build/
coverage/

# --------------------------
# Google Apps Script
# --------------------------
.clasp.json

# --------------------------
# IDE
# --------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

.idea/

# --------------------------
# Temporary Files
# --------------------------
*.tmp
*.temp
*.bak
*.swp

# --------------------------
# Archives
# --------------------------
*.zip
*.rar
*.7z

# --------------------------
# Generated Files
# --------------------------
*.cache
.cache/

# --------------------------
# Secrets
# --------------------------
secrets/
credentials/